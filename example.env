# انسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك:
#   cp example.env .env

# رابط واجهة الـ API
VITE_API_URL="http://localhost:3000/api/v1"

# انتهاء الاشتراك: تاريخ فقط YYYY-MM-DD — آخر لحظة من ذلك اليوم بتوقيت UTC+3.
# أو صيغة ISO كاملة إن احتجت وقتاً محدداً. اترك القيمة فارغة لتعطيل قفل المنصة.
VITE_SUBSCRIPTION_EXPIRES_AT=

# رابط صفحة التجديد أو الدفع (زر «اشترك الآن»). يُفضّل https://
VITE_SUBSCRIPTION_RENEW_URL=

# --- أمثلة للقيم (للنسخ عند الحاجة) ---
# VITE_SUBSCRIPTION_EXPIRES_AT=2026-12-31
# VITE_SUBSCRIPTION_RENEW_URL=https://example.com/subscribe
